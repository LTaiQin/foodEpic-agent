# OpenAI-compatible endpoint used by the current food agent setup.
OPENAI_BASE_URL=https://right.codes/codex/v1
OPENAI_API_KEY=replace-with-your-key
FOOD_AGENT_MODEL=gpt-5.4
# Text generation stays on `responses`; vision auto-detects and can fall back.
FOOD_AGENT_PROVIDER_MODE=responses
FOOD_AGENT_VISION_PROVIDER_MODE=auto
